# StoreClaw 环境地址。QA: https://www.storeclawdev.com, 线上: https://www.storeclaw.ai。
STORECLAW_BASE_URL=https://www.storeclawdev.com

# 登录账号。请在本地 .env 中填写真实账号，.env.example 不要提交真实账号。
STORECLAW_EMAIL=your-email@example.com

# 登录密码。请在本地 .env 中填写真实密码，.env.example 不要提交真实密码。
STORECLAW_PASSWORD=your-password

# JSON 批量用例路径。可以指向单个 JSON 文件，也可以指向目录；目录模式会按文件名排序加载所有 *.json。
STORECLAW_CASES_FILE=tests/data

# 单个 HTTP 接口请求的等待超时时间，单位秒。1800 秒等于 30 分钟。
# 这是运行层面的请求等待时间；JSON 里的 max_duration_seconds 是可选的业务耗时断言，默认用例不需要重复配置。
STORECLAW_TIMEOUT=1800

# 批量执行时的最大并发会话链数量。系统限制单账号最多 10 个会话同时进行，取值范围 1 到 10。
STORECLAW_MAX_CONCURRENCY=1

# SSE 收到 RunCompleted 后，如果 session runs 暂时为空，最多继续等待多久，单位秒。
STORECLAW_RUNS_POLL_TIMEOUT=120

# session runs 为空时的轮询间隔，单位秒。
STORECLAW_RUNS_POLL_INTERVAL=5

# DeepSeek/OpenAI-compatible Judge API 地址。DeepSeek 填 https://api.deepseek.com。
STORECLAW_JUDGE_BASE_URL=https://api.deepseek.com

# Judge 模型名称。DeepSeek 常用 deepseek-chat；如后续切换模型，只改本地 .env。
STORECLAW_JUDGE_MODEL=deepseek-chat

# Judge API Key。只填写到本地 .env，.env.example 不要提交真实 key。
STORECLAW_JUDGE_API_KEY=your-judge-api-key

# Judge 单次请求超时时间，单位秒。默认 300，避免模型响应较慢时被过早中断。
STORECLAW_JUDGE_TIMEOUT=300

# Judge 全局达标分。JSON 用例里不再配置 pass_score，统一走这个环境变量。
STORECLAW_JUDGE_PASS_SCORE=80

# Judge 调用失败时是否让当前 case 失败。true 表示失败，false 表示记录错误但不中断 case。
STORECLAW_JUDGE_FAIL_ON_ERROR=true

# 传给 Judge 的 StoreClaw 最终回复最大字符数。默认 50000；超过时保留头部证据和尾部最终回答。
STORECLAW_JUDGE_MAX_RESPONSE_CHARS=50000
